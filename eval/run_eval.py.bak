#!/usr/bin/env python3
import json
from datetime import datetime, timezone
from pathlib import Path
import subprocess
import sys

ROOT = Path(__file__).resolve().parents[1]
QUESTIONS = ROOT / "eval" / "questions.jsonl"
OUT_DIR = ROOT / "eval" / "results"


def main() -> None:
    OUT_DIR.mkdir(parents=True, exist_ok=True)
    ts = datetime.now(timezone.utc).astimezone().strftime("%Y%m%d-%H%M%S")
    out_path = OUT_DIR / f"{ts}.jsonl"

    if not QUESTIONS.exists():
        raise SystemExit(f"questions not found: {QUESTIONS}")

    lines = [l.strip() for l in QUESTIONS.read_text(encoding="utf-8").splitlines() if l.strip()]
    results = []

    for line in lines:
        q = json.loads(line)
        qid = q["id"]
        question = q["question"]

        # ask.py をCLIとして叩く（依存関係が増えない・壊れにくい）
        p = subprocess.run(
            [sys.executable, str(ROOT / "src" / "ask.py"), question],
            capture_output=True,
            text=True,
        )

        answer = (p.stdout or "").strip()
        err = (p.stderr or "").strip()

        has_sources = ("参照:" in answer) or ("sources" in answer.lower())
        mentions_unknown = ("不明" in answer)

        rec = {
            "id": qid,
            "question": question,
            "exit_code": p.returncode,
            "has_sources": has_sources,
            "mentions_unknown": mentions_unknown,
            "answer": answer,
            "stderr": err,
        }
        results.append(rec)
        out_path.write_text("\n".join(json.dumps(r, ensure_ascii=False) for r in results) + "\n", encoding="utf-8")
        print(f"[eval] {qid} exit={p.returncode} sources={has_sources}")

    print(f"[eval] saved: {out_path}")


if __name__ == "__main__":
    main()
