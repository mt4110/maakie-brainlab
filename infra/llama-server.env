# llama-server の実体
LLAMA_SERVER_BIN="${LLAMA_SERVER_BIN:-$(command -v llama-server 2>/dev/null || echo "$HOME/llama.cpp/build/bin/llama-server")}"

# GGUF モデル（あなたの配置先に合わせる）
LLAMA_MODEL="${LLAMA_MODEL:-$PWD/models/Qwen2.5-7B-Instruct-Q4_K_M.gguf}"

# Listen
LLAMA_HOST="${LLAMA_HOST:-127.0.0.1}"
LLAMA_PORT="${LLAMA_PORT:-8080}"

# 推論設定（まずは現状踏襲）
LLAMA_CTX="${LLAMA_CTX:-4096}"
LLAMA_NGL="${LLAMA_NGL:-29}"

# 追加オプション（必要になったらここにだけ足す）
LLAMA_EXTRA_ARGS="${LLAMA_EXTRA_ARGS:-}"
