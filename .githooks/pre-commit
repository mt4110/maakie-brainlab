#!/usr/bin/env bash
# .githooks/pre-commit
# AI Text Guard — Hygiene Capsule (auto-fix + verify)
#
# Contract:
# - Run the fixer, then run the checker.
# - Stage ONLY the fixer's outputs inside the capsule scope.
# - Never touch (re-stage) whatever you already staged outside that scope.
# - Fail closed when the capsule scope is "mixed" (has unstaged diffs), because
#   auto-fix + restage would clobber partial-staging.
#
# Escape hatch (use sparingly; leaves an obvious trace in your shell history):
#   SKIP_AI_TEXT_GUARD=1 git commit ...

echo "== Pre-commit: AI Text Guard (Capsule) =="

if [ "${SKIP_AI_TEXT_GUARD:-}" = "1" ]; then
  echo "[WARN] SKIP_AI_TEXT_GUARD=1 (guard skipped)"
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$ROOT" ]; then
  # Not a git repo (or git unavailable) — do nothing.
  exit 0
fi

cd "$ROOT" || exit 0

FIXER="ops/finalize_clean.sh"
if [ ! -f "$FIXER" ]; then
  echo "[FATAL] missing $FIXER"
  exit 1
fi

# The only paths this capsule is allowed to auto-stage.
SCOPE=(docs ops .github internal .githooks)

echo "== 0) Preflight (fail closed on mixed scope) =="
UNSTAGED_IN_SCOPE="$(git diff --name-only -- "${SCOPE[@]}" 2>/dev/null || true)"
if [ -n "$UNSTAGED_IN_SCOPE" ]; then
  echo "[FATAL] Unstaged changes exist inside capsule scope."
  echo "This would risk clobbering partial-staging. Resolve first:"
  echo "  - stage them, or stash them, then retry commit"
  echo ""
  printf "%s\n" "$UNSTAGED_IN_SCOPE"
  exit 1
fi

echo "== 1) Auto-fix =="
# Snapshot *which files are already dirty* before the fixer runs.
DIRTY_BEFORE="$(git diff --name-only 2>/dev/null || true)"

bash "$FIXER" --fix
rc=$?
if [ $rc -ne 0 ]; then
  echo "[FATAL] auto-fix failed (exit=$rc)"
  exit $rc
fi

echo "== 2) Stage fixer outputs (scope only) =="
# Stage ONLY what the fixer changed within scope.
# (Because scope was clean preflight, these are fixer-only diffs.)
STAGE_OK=1
while IFS= read -r -d '' f; do
  [ -n "$f" ] || continue
  if ! git add -- "$f"; then
    echo "[FATAL] failed to stage: $f"
    STAGE_OK=0
  fi
done < <(git diff --name-only -z -- "${SCOPE[@]}" 2>/dev/null || true)

if [ $STAGE_OK -ne 1 ]; then
  exit 1
fi

echo "== 3) Guardrail: fixer must not touch outside scope =="
DIRTY_AFTER="$(git diff --name-only 2>/dev/null || true)"

# NEW = after - before (set difference)
# We use comm to find lines in after that are not in before
# Pre-requisite: inputs must be sorted
NEW_DIRTY="$(comm -13 \
  <(printf "%s\n" "$DIRTY_BEFORE" | LC_ALL=C sort -u) \
  <(printf "%s\n" "$DIRTY_AFTER"  | LC_ALL=C sort -u) \
  | sed '/^$/d' || true
)"

# Check if any new dirty file is outside scope
NEW_OUTSIDE="$(printf "%s\n" "$NEW_DIRTY" | grep -Ev '^(docs/|ops/|\.github/|internal/|\.githooks/)' || true)"
if [ -n "$NEW_OUTSIDE" ]; then
  echo "[FATAL] auto-fix made new edits outside capsule scope:"
  printf "%s\n" "$NEW_OUTSIDE"
  echo "Resolve manually or expand capsule scope intentionally."
  exit 1
fi

echo "== 4) Final check =="
bash "$FIXER" --check
rc=$?
if [ $rc -ne 0 ]; then
  echo "[FATAL] check failed (exit=$rc)"
  echo "Tip: run: bash $FIXER --fix && bash $FIXER --check"
  exit $rc
fi

echo "[OK] AI Text Guard"
exit 0
