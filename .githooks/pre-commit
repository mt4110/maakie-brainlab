#!/usr/bin/env bash
# .githooks/pre-commit
# AI Text Guard — Hygiene Capsule (auto-fix + verify)
#
# Contract:
# - Run the checker first; if OK, do nothing.
# - If NOT OK, run the fixer, then re-check.
# - Stage ONLY tracked fixer outputs inside the capsule scope.
# - Fail closed when:
#     * capsule scope has unstaged diffs (partial-staging risk)
#     * anything outside scope has unstaged diffs (keep worktree stable)
#     * fixer touches outside scope or creates untracked files in scope
#
# Escape hatch (use sparingly; leaves an obvious trace in your shell history):
#   SKIP_AI_TEXT_GUARD=1 git commit ...

echo "== Pre-commit: AI Text Guard (Capsule) =="

if [ "${SKIP_AI_TEXT_GUARD:-}" = "1" ]; then
  echo "[WARN] SKIP_AI_TEXT_GUARD=1 (guard skipped)"
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$ROOT" ]; then
  # Not a git repo (or git unavailable) — do nothing.
  exit 0
fi

cd "$ROOT" || exit 0

GITDIR="$(git rev-parse --git-dir 2>/dev/null || true)"
if [ -n "$GITDIR" ]; then
  if [ -f "$GITDIR/MERGE_HEAD" ] || [ -f "$GITDIR/CHERRY_PICK_HEAD" ] || [ -f "$GITDIR/REVERT_HEAD" ] || [ -d "$GITDIR/rebase-apply" ] || [ -d "$GITDIR/rebase-merge" ]; then
    echo "[FATAL] git operation in progress (merge/rebase/cherry-pick/revert)."
    echo "Finish it (or abort) before committing."
    exit 1
  fi
fi

FIXER="ops/finalize_clean.sh"
if [ ! -f "$FIXER" ]; then
  echo "[FATAL] missing $FIXER"
  exit 1
fi

# The only paths this capsule is allowed to touch / stage.
SCOPE=(docs ops .github internal .githooks)

echo "== 0) Preflight (fail closed) =="

# A) Partial-staging risk: scope must not be mixed (unstaged diffs).
UNSTAGED_IN_SCOPE="$(git diff --name-only -- "${SCOPE[@]}" 2>/dev/null || true)"
if [ -n "$UNSTAGED_IN_SCOPE" ]; then
  echo "[FATAL] Unstaged changes exist inside capsule scope."
  echo "This would risk clobbering partial-staging. Resolve first:"
  echo "  - stage them, or stash them, then retry commit"
  echo ""
  printf "%s\n" "$UNSTAGED_IN_SCOPE"
  exit 1
fi

# B) Safety: keep the rest of the worktree stable while auto-fixing.
UNSTAGED_OUTSIDE="$(git diff --name-only 2>/dev/null | grep -Ev '^(docs/|ops/|\.github/|internal/|\.githooks/)' || true)"
if [ -n "$UNSTAGED_OUTSIDE" ]; then
  echo "[FATAL] Unstaged changes exist outside capsule scope."
  echo "Auto-fix must run on a stable worktree. Resolve first:"
  echo "  - stage them, or stash them, then retry commit"
  echo ""
  printf "%s\n" "$UNSTAGED_OUTSIDE"
  exit 1
fi

echo "== 1) Check (fast path) =="
bash "$FIXER" --check
rc=$?
if [ $rc -eq 0 ]; then
  echo "[OK] AI Text Guard (no changes needed)"
  exit 0
fi

echo "== 2) Auto-fix =="
bash "$FIXER" --fix
rc=$?
if [ $rc -ne 0 ]; then
  echo "[FATAL] auto-fix failed (exit=$rc)"
  exit $rc
fi

echo "== 3) Guardrail: fixer must not touch outside scope =="
OTHER="$(git diff --name-only 2>/dev/null | grep -Ev '^(docs/|ops/|\.github/|internal/|\.githooks/)' || true)"
if [ -n "$OTHER" ]; then
  echo "[FATAL] auto-fix modified files outside capsule scope:"
  printf "%s\n" "$OTHER"
  echo "[INFO] reverting those worktree changes (restore from index)..."
  printf "%s\n" "$OTHER" | while IFS= read -r f; do
    [ -n "$f" ] || continue
    git restore --worktree -- "$f" 2>/dev/null || git checkout -- "$f" 2>/dev/null || true
  done
  exit 1
fi

echo "== 4) Guardrail: fixer must not create untracked files in scope =="
UNTRACKED_IN_SCOPE="$(git ls-files --others --exclude-standard -- "${SCOPE[@]}" 2>/dev/null || true)"
if [ -n "$UNTRACKED_IN_SCOPE" ]; then
  echo "[FATAL] auto-fix created untracked files in capsule scope:"
  printf "%s\n" "$UNTRACKED_IN_SCOPE"
  echo "Stage them manually if intended, or adjust the fixer."
  exit 1
fi

echo "== 5) Stage fixer outputs (tracked, scope only) =="
# Stage tracked modifications + deletions in scope, without adding new files.
git add -u -- "${SCOPE[@]}"
rc=$?
if [ $rc -ne 0 ]; then
  echo "[FATAL] failed to stage fixer outputs in scope (exit=$rc)"
  exit $rc
fi

echo "== 6) Final check =="
bash "$FIXER" --check
rc=$?
if [ $rc -ne 0 ]; then
  echo "[FATAL] check failed (exit=$rc)"
  echo "Tip: run: bash $FIXER --fix && bash $FIXER --check"
  exit $rc
fi

echo "[OK] AI Text Guard"
exit 0
