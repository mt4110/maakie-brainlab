#!/bin/bash
# .githooks/pre-commit
# Enforce AI Text Guard

echo "== Pre-commit: AI Text Guard (Auto-Fixing) =="

# 1. Attempt auto-fix
bash ops/finalize_clean.sh --fix

# 2. Re-stage any modified files
# We use git add -u to update tracked files that were modified by the fix
git add -u

# 3. Final Check (Verification)
# If fix failed or didn't catch something, this will fail the commit
bash ops/finalize_clean.sh --check
